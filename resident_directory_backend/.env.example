# Backend configuration (ask orchestrator to set these in the container .env)

# Preferred: full SQLAlchemy async URL
POSTGRES_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME

# JWT signing secret (set to a strong random value in production)
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
CORS_ALLOW_ORIGINS=*
